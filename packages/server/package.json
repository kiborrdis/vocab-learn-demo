{
  "name": "server",
  "packageManager": "yarn@4.3.1",
  "dependencies": {
    "@google/genai": "^1.11.0",
    "@prisma/client": "^6.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "openapi-types": "^12.1.3",
    "prisma": "^6.9.0",
    "telegraf": "^4.16.3",
    "uid": "^2.0.2",
    "wink-lemmatizer": "^3.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.5.3",
    "tsc-helpers": "https://github.com/kiborrdis/tsc-helpers",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.4"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "codegen": "prisma generate && tsx ./codegen/runCodegen.ts ",
    "build": "tsc && yarn prisma:migrate:deploy",
    "start": "node dist/index.js",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "format": "prettier --write ./src",
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format:check": "prettier --check ./src",
    "validate": "yarn format:check && yarn typecheck && yarn lint"
  }
}
