{
  "manifest_version": 3,
  "name": "Language Learn Extension",
  "version": "1.0.0",
  "description": "A Chrome extension to facilitate language learning.",
  "permissions": ["storage", "activeTab", "clipboardRead", "contextMenus"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16x16.png",
      "48": "icon-48x48.png",
      "128": "icon-128x128.png"
    }
  },
  "icons": {
    "16": "icon-16x16.png",
    "48": "icon-48x48.png",
    "128": "icon-128x128.png"
  },
  "content_scripts": []
}
